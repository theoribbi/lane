{
  "git": {
    "commitMessage": "chore: release lane@${version}",
    "tagName": "lane@${version}",
    "tagAnnotation": "lane@${version}",
    "requireCleanWorkingDir": true,
    "requireBranch": "main"
  },
  "npm": {
    "publish": true
  },
  "github": {
    "release": true,
    "releaseName": "lane@${version}"
  },
  "hooks": {
    "before:init": ["pnpm test", "pnpm typecheck"],
    "after:bump": "pnpm build"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md"
    }
  }
}
