{
  "name": "@theoribbi/lane",
  "version": "0.1.0",
  "description": "Isolated multi-repo worktree dev environments — cloned DBs, derived ports, zero env wiring.",
  "type": "module",
  "license": "MIT",
  "author": "Théo Ribbi <theo@ribbi.ch>",
  "homepage": "https://github.com/theoribbi/lane#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theoribbi/lane.git"
  },
  "bugs": {
    "url": "https://github.com/theoribbi/lane/issues"
  },
  "keywords": [
    "git-worktree",
    "developer-tools",
    "cli",
    "ai-agents",
    "monorepo",
    "docker-compose",
    "postgres",
    "mysql",
    "devex",
    "typescript"
  ],
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "lane": "./dist/cli.js"
  },
  "files": [
    "dist",
    "scripts/check-manifest-drift.mjs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.5.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
